NOTEGATE_DATABASE_URL=postgres://notegate:notegate@localhost:5433/notegate
NOTEGATE_AUTHGATE_URL=https://authgate.project-jelly.io
NOTEGATE_PUBLIC_URL=http://localhost:9191
NOTEGATE_OAUTH_CLIENT_ID=notegate-web
NOTEGATE_MCP_OAUTH_CLIENT_ID=notegate-mcp
NOTEGATE_ENC_ROOT_KEY_ID=dev-enc
NOTEGATE_ENC_ROOT_SECRET=replace-with-distinct-enc-root-secret-32b
NOTEGATE_LOOKUP_ROOT_KEY_ID=dev-lookup
NOTEGATE_LOOKUP_ROOT_SECRET=replace-with-distinct-lookup-root-secret-32b

# The bucket must already exist; Notegate never creates it.
# Docker Compose's minio-init service provisions this development bucket.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:5173,http://localhost:9191
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=minio-root-secret
NOTEGATE_S3__ENDPOINT=http://localhost:9000
NOTEGATE_S3__PUBLIC_ENDPOINT=http://localhost:9000
NOTEGATE_S3__REGION=us-east-1
NOTEGATE_S3__BUCKET=notegate
NOTEGATE_S3__ACCESS_KEY=notegate-app
NOTEGATE_S3__SECRET_KEY=notegate-app-secret
NOTEGATE_S3__FORCE_PATH_STYLE=true

LOG_FORMAT=
RUST_LOG=notegate_api=info,notegate_db=info,tower_http=info
