NOTEGATE_DATABASE_URL=postgres://notegate:notegate@localhost:5433/notegate
NOTEGATE_AUTHGATE_URL=https://authgate.project-jelly.io
NOTEGATE_PUBLIC_URL=http://localhost:9191
NOTEGATE_OAUTH_CLIENT_ID=notegate-web
NOTEGATE_MCP_OAUTH_CLIENT_ID=notegate-mcp
NOTEGATE_ENC_ROOT_KEY_ID=dev-enc
NOTEGATE_ENC_ROOT_SECRET=replace-with-distinct-enc-root-secret-32b
NOTEGATE_LOOKUP_ROOT_KEY_ID=dev-lookup
NOTEGATE_LOOKUP_ROOT_SECRET=replace-with-distinct-lookup-root-secret-32b

LOG_FORMAT=
RUST_LOG=notegate_api=info,notegate_db=info,tower_http=info
