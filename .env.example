# Copy to `.env` for local development. `.env` is git-ignored.
#
# Required runtime settings.
NOTEGATE_DATABASE_URL=postgres://notegate:notegate@localhost:5433/notegate
NOTEGATE_AUTHGATE_URL=https://authgate.project-jelly.io
NOTEGATE_PUBLIC_URL=http://localhost:9191
NOTEGATE_OAUTH_CLIENT_ID=notegate-web
NOTEGATE_MCP_OAUTH_CLIENT_ID=notegate-mcp
NOTEGATE_ENC_ROOT_KEY_ID=dev-enc
NOTEGATE_ENC_ROOT_SECRET=replace-with-distinct-enc-root-secret-32b
NOTEGATE_LOOKUP_ROOT_KEY_ID=dev-lookup
NOTEGATE_LOOKUP_ROOT_SECRET=replace-with-distinct-lookup-root-secret-32b

# `json` for structured logs; anything else for human-readable.
LOG_FORMAT=
# Tracing filter, e.g. notegate_api=debug,sqlx=warn
RUST_LOG=notegate_api=info,notegate_db=info,tower_http=info

# Optional during LOOKUP root migration only.
# NOTEGATE_LOOKUP_VERIFY_0_KEY_ID=old-lookup
# NOTEGATE_LOOKUP_VERIFY_0_SECRET=replace-with-old-lookup-root-secret

# Default tier for newly created users.
# Leave unset for local/system-max development. Set `tier0` before constrained production signup.
# NOTEGATE_DEFAULT_USER_TIER=tier0

# Optional: lower capacity caps for cheap local/E2E boundary tests.
# Defaults match docs/spec/performance-limits.md when unset.
# NOTEGATE_LIMITS__FOLDER_MAX_CHILDREN=3
# NOTEGATE_LIMITS__SPACE_MAX_NODES=5
# NOTEGATE_LIMITS__SPACE_MAX_CONTENT_BYTES=1024
